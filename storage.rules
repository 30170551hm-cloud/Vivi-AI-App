rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User uploads used in chat/tools
    match /uploads/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
        && request.resource.size < 25 * 1024 * 1024;
    }

    // Vivi workspace artifacts (reports, generated assets, traces)
    match /vivi-artifacts/{userId}/workspace/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
        && request.resource.size < 10 * 1024 * 1024;
    }

    // TTS cache generated via Cloud Functions
    match /vivi-artifacts/{userId}/tts-cache/{fileName} {
      allow read: if isOwner(userId);
      allow write: if false; // only backend/Admin SDK should write
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
