// Firestore Security Rules — borrador para la migración desde Base44.
// NO DESPLEGADO TODAVÍA. Revisar y probar en el emulador de Firebase antes
// de aplicar a un proyecto real (firebase emulators:start --only firestore).
//
// Principio: cada documento pertenece a un usuario (ownerId == request.auth.uid),
// replicando el aislamiento row-level que hoy provee Base44 automáticamente.
// El founder (is_founder == true en users/{uid}) obtiene lectura ampliada
// donde el diseño actual de Vivi lo requiere (Founder Panel, VDE Console).

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isOwnerOnCreate() {
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    function isFounder() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_founder == true;
    }

    // ── users/{uid} — perfil y preferencias (equivalente a base44 User entity) ──
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isFounder());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── memories/{id} — equivalente a base44 Memory entity ──
    match /memories/{memoryId} {
      allow read, update, delete: if isOwner(resource);
      allow create: if isOwnerOnCreate();
    }

    // ── conversations/{id} — equivalente a base44 Conversation entity ──
    match /conversations/{conversationId} {
      allow read, update, delete: if isOwner(resource);
      allow create: if isOwnerOnCreate();
    }

    // ── chat_messages/{id} — equivalente a base44 ChatMessage entity ──
    match /chat_messages/{messageId} {
      allow read, update, delete: if isOwner(resource);
      allow create: if isOwnerOnCreate();
    }

    // ── tool_actions/{id} — equivalente a base44 ToolAction entity ──
    match /tool_actions/{actionId} {
      allow read: if isOwner(resource) || isFounder();
      allow create: if isOwnerOnCreate();
      allow update, delete: if isFounder();
    }

    // ── improvement_proposals/{id} — equivalente a base44 ImprovementProposal ──
    // Solo el founder gestiona el ciclo de auto-mejora (VDE).
    match /improvement_proposals/{proposalId} {
      allow read, write: if isFounder();
    }

    // ── certification_tests/{id} — equivalente a base44 CertificationTest ──
    match /certification_tests/{testId} {
      allow read, write: if isFounder();
    }

    // Por defecto: negar todo lo no listado explícitamente.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
