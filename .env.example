# ── Base44 (legacy — do not remove until migration to Firebase is complete) ──
VITE_BASE44_APP_ID=
VITE_BASE44_FUNCTIONS_VERSION=
VITE_BASE44_APP_BASE_URL=

# ── Firebase ──
# Get these values from Firebase Console: https://console.firebase.google.com/
# Project Settings → Service Accounts → Web SDK snippets
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Gemini AI ──
# Create free API key at https://aistudio.google.com/apikey
# ⚠️ WARNING: Restrict this key by HTTP referrer in Google Cloud Console
#    to prevent abuse. The key will be visible in the browser bundle.
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-1.5-flash
